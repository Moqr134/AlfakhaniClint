@page "/ManagerBills"
@layout MainLayout
@implements IAsyncDisposable
<h2 class="mb-4 text-center">📋 إدارة الفواتير</h2>
@if(bills == null || !bills.Any())
{
<div class="alert alert-info text-center">
    لا توجد طلبات حالياً.
</div>
}
else
{
@foreach (var ordar in bills)
{
        <div class="admin-order-card">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h5>الطلب رقم #@ordar.Id</h5>
                <p class="mb-1">الوقت : @ordar.Date.ToLongTimeString()</p>
                <p class="mb-1">الاسم : @ordar.Name</p>
                <p class="mb-1">اسم العامل : @ordar.UpdatedBy</p>
                <p class="mb-1">المجموع : @ordar.TotalAmount د.ع</p>
                @if (ordar.Status == "Cancelled")
                {
                    <p class="mb-1 text-danger">الحالة : <strong>مرفوض</strong></p>
                    <p class="mb-1 text-danger">سبب الرفض : @ordar.RefuseReason</p>
                }
                else
                {
                    <p class="mb-1 text-sucsess">الحالة : <strong>كامل</strong></p>
                }
            </div>
        </div>
    </div>
}
}