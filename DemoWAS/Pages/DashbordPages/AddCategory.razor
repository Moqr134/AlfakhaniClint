@page "/addcategory"
@layout MainLayout
<div class="container">
    <div class="form-container">
      <h3 class="text-center mb-4"><i class="bi bi-plus-circle"></i> إضافة طبق جديد</h3>
      <form>
            <div class="mb-3">
                <label for="name" class="form-label">اسم الصنف</label>
                <input type="text" @bind="@Category.CategoryName" class="form-control" id="name" placeholder="مثال: بيتزا">
            </div>
            <div class="text-center">
                <button type="button" @onclick="AddCategoryAsync" class="btn btn-submit px-5">إضافة الطبق</button>
            </div>
      </form>
    </div>
</div>
