@page "/categorymanagement"
@layout MainLayout
<div class="container">
    <div class="page-header">
        <h2><i class="bi bi-grid"></i> إدارة التصنيفات</h2>
        <button @onclick="AddCategory" class="btn btn-add mt-3"><i class="bi bi-plus-circle"></i> إضافة صنف جديد</button>
    </div>
    <div class="table-responsive">
        <table class="table table-dark table-hover text-center align-middle">
            <thead class="table-success text-dark">
                <tr>
                    <th>رقم الصنف</th>
                    <th>الاسم</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (categories != null && categories.Count > 0)
                {
                    foreach (var category in categories)
                    {
                        <tr>
                            <td>@category.Id</td>
                            <td>@category.CategoryName</td>
                            <td class="action-btns">
                                <button @onclick="()=>UpdateCategory(category.Id)" class="btn btn-sm btn-outline-light"><i class="bi bi-pencil"></i></button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">لا توجد اصناف</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>