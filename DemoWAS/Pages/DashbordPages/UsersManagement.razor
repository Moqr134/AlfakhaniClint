@page "/usersmanagement"
@layout MainLayout
<div class="container">
    <div class="page-header">
        <h2><i class="bi bi-person"></i> إدارة المستخدمين</h2>
    </div>
    <div >
        <input type="text" class="form-control mb-3" @bind="SearchEmail" placeholder="ابحث عن مستخدم..." />
        <button @onclick="SearchUserByName" class="btn btn-primary mb-3"><i class="bi bi-search"></i>بحث عن طريق الاسم</button>
    </div>
    <div class="table-responsive">
        <table class="table table-dark table-hover text-center align-middle">
            <thead class="table-success text-dark">
                <tr>
                    <th>الاسم</th>
                    <th>الصلاحية</th>
                    <th>إجراء</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var user in userOuts)
                {
                    <tr>
                        <td>@user.Name</td>
                        <td><span class="badge bg-success">@user.Role</span></td>
                        @if (user.Role == "Admin")
                        {
                            <td class="action-btns"><button @onclick="() => MakeAdminUser(user.Id)" class="btn btn-sm btn-outline-light"><i class="bi bi-person-x"></i> حذف الادمنية</button></td>

                        }
                        else
                        {
                            <td class="action-btns"><button @onclick="()=>MakeUserAdmin(user.Id)" class="btn btn-sm btn-outline-light"><i class="bi bi-person-add"></i> اجعله أدمن</button></td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>