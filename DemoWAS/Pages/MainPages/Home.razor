@page "/home"
@layout HomeLayout
@using DemoWAS.Layout
@using Microsoft.AspNetCore.SignalR.Client
@using System.Net
@using DemoWAS.Service
@using SherdProject.DTO
@inject IJSRuntime js
@inject NavigationManager NavigationManager
@inject IUserService UserService
<section class="hero-section">
    <div class="container">
        <img src="images/AlFkhaniLogo.jpg" alt="مطعم أونلاين" class="hero-image">
        <h1>مرحباً بك في الفاكهاني</h1>
        <p>الفاكهاني صار بين أيديك بكل مكان. أطلب الان بكل سهولة!</p>
        <a href="/menu" class="btn btn-order">ابدأ الطلب</a>
    </div>
</section>

<section class="info-cards">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-4 mb-4">
                <div class="card p-4 h-100">
                    <div class="info-icon"><i class="bi bi-emoji-smile"></i></div>
                    <h3 class="card-title">مكونات طازجة</h3>
                    <p class="card-text">نستخدم أفضل المكونات الطازجة في كل منتج لضمان الجودة والطعم الأصيل.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card p-4 h-100">
                    <div class="info-icon"><i class="bi bi-truck"></i></div>
                    <h3 class="card-title">توصيل سريع</h3>
                    <p class="card-text">نضمن توصيل طلبك في الوقت المحدد وبأفضل حال.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card p-4 h-100">
                    <div class="info-icon"><i class="bi bi-headset"></i></div>
                    <h3 class="card-title">خدمة عملاء مميزة</h3>
                    <p class="card-text">فريقنا جاهز دائمًا لمساعدتك وتلبية جميع استفساراتك.</p>
                </div>
            </div>
        </div>
    </div>
</section>